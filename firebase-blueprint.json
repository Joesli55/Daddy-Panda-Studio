{
  "entities": {
    "ContactDownload": {
      "title": "ContactDownload",
      "description": "Record of a user downloading the vCard",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person downloading the contact"
        },
        "email": {
          "type": "string",
          "description": "Email of the person downloading the contact"
        },
        "instagram": {
          "type": "string",
          "description": "Instagram handle (optional)"
        },
        "downloadedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the download"
        }
      },
      "required": ["name", "email", "downloadedAt"]
    }
  },
  "firestore": {
    "/contact_downloads/{downloadId}": {
      "schema": {
        "$ref": "#/entities/ContactDownload"
      },
      "description": "Collection of contact downloads"
    }
  }
}
